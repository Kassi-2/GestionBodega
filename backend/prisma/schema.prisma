generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model product {
  id        Int    @id @default(autoincrement())
  name    String
  description String?
  stock     Int? @default(0)
  criticalStock Int?
  state     String @default("activo")
  @@unique([name])
}
